# --- Database (Postgres: Neon / Vercel Postgres / local) ---
# e.g. postgresql://user:pass@ep-xxx.neon.tech/jobscout?sslmode=require
DATABASE_URL=

# --- LLM providers (all optional; pick the active one in Settings) ---
# Cloud providers: set the key for whichever you use.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Local models via an OpenAI-compatible server (Ollama / LM Studio).
# Ollama example: http://localhost:11434/v1
LOCAL_LLM_BASE_URL=
LOCAL_LLM_API_KEY=

# --- LLM routing via env (for hosted deploys where config can't be saved to
# disk). Optional; overrides jobscout.config.json. Provider: anthropic|openai|
# google|local. Leave unset to use the Settings UI / config file locally. ---
LLM_PROVIDER=
LLM_MODEL_FAST=
LLM_MODEL_QUALITY=
LLM_TASK_SCORING=
LLM_TASK_EXTRACTION=
LLM_TASK_RESUME=
LLM_TASK_DRAFTING=

# Shared secret protecting the /api/cron endpoint (set to a random string on
# Vercel; Vercel Cron sends it automatically as a Bearer token).
CRON_SECRET=

# --- Job sources (all optional; free sources work with no keys) ---
# JSearch (RapidAPI) — LinkedIn/Indeed/Glassdoor/ZipRecruiter aggregate.
RAPIDAPI_KEY=
# Adzuna aggregator — free app id/key from https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# ATS company boards to poll (public, no key). Comma-separated provider:token,
# where token is the company's board slug. Example:
# ATS_COMPANIES=greenhouse:stripe,lever:netflix,ashby:openai
ATS_COMPANIES=
